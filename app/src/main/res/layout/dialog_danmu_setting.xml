<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/shape_dialog_bg_main"
        android:paddingLeft="@dimen/vs_30"
        android:paddingTop="@dimen/vs_24"
        android:paddingRight="@dimen/vs_30"
        android:paddingBottom="@dimen/vs_24"
        android:layout_width="@dimen/vs_520"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/ts_26"
            android:textStyle="bold"
            android:textColor="@color/color_CC000000"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_20"
            android:text="弹幕设置"
            android:singleLine="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8">
            <TextView
                android:textSize="@dimen/ts_22"
                android:textColor="@color/color_CC000000"
                android:gravity="left"
                android:layout_gravity="center"
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:text="弹幕开关"/>
            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:orientation="horizontal"
                android:id="@+id/trv_onoff"
                android:layout_width="0.0dip"
                android:layout_height="@dimen/vs_50"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/vs_20"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_10"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_10"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8">
            <TextView
                android:textSize="@dimen/ts_22"
                android:textColor="@color/color_CC000000"
                android:gravity="left"
                android:layout_gravity="center"
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:text="弹幕颜色"/>
            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:orientation="horizontal"
                android:id="@+id/trv_color"
                android:layout_width="0.0dip"
                android:layout_height="@dimen/vs_50"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/vs_20"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_10"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_10"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8">
            <TextView
                android:textSize="@dimen/ts_22"
                android:textColor="@color/color_CC000000"
                android:layout_gravity="center"
                android:gravity="left"
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:text="弹幕速度"/>
            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:orientation="horizontal"
                android:id="@+id/speed"
                android:layout_width="0.0dip"
                android:layout_height="@dimen/vs_50"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/vs_20"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_10"
                app:tv_layoutManager="V7LinearLayoutManager"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_10"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8">
            <TextView
                android:textSize="@dimen/ts_22"
                android:textColor="@color/color_CC000000"
                android:gravity="left"
                android:layout_gravity="center"
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:text="弹幕大小"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="0.0dip"
                android:layout_height="@dimen/vs_50"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/vs_20">
                <TextView
                    android:textSize="@dimen/ts_24"
                    android:textColor="@color/color_FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/sizeSub"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:text="-"/>
                <TextView
                    android:textSize="@dimen/ts_20"
                    android:textColor="@color/color_CC000000"
                    android:gravity="center"
                    android:id="@+id/size"
                    android:layout_width="0.0dip"
                    android:layout_height="fill_parent"
                    android:layout_weight="1.0"/>
                <TextView
                    android:textSize="@dimen/ts_24"
                    android:textColor="@color/color_FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/sizeAdd"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:text="+"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/vs_8">
            <TextView
                android:textSize="@dimen/ts_22"
                android:textColor="@color/color_CC000000"
                android:layout_gravity="center"
                android:gravity="left"
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:text="弹幕行数"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="0.0dip"
                android:layout_height="@dimen/vs_50"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/vs_20">
                <TextView
                    android:textSize="@dimen/ts_24"
                    android:textColor="@color/color_FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/lineSub"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:text="-"/>
                <TextView
                    android:textSize="@dimen/ts_20"
                    android:textColor="@color/color_CC000000"
                    android:gravity="center"
                    android:id="@+id/line"
                    android:layout_width="0.0dip"
                    android:layout_height="fill_parent"
                    android:layout_weight="1.0"/>
                <TextView
                    android:textSize="@dimen/ts_24"
                    android:textColor="@color/color_FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/lineAdd"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:text="+"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="@dimen/vs_5"
            android:paddingBottom="@dimen/vs_5"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/ts_22"
                android:textColor="@color/color_CC000000"
                android:layout_gravity="center"
                android:gravity="left"
                android:layout_width="@dimen/vs_120"
                android:layout_height="@dimen/vs_50"
                android:text="弹幕透明"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="0.0dip"
                android:layout_height="@dimen/vs_50"
                android:layout_weight="1.0"
                android:layout_marginStart="@dimen/vs_20">
                <TextView
                    android:textSize="@dimen/ts_24"
                    android:textColor="@color/color_FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/alphaSub"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:text="-"/>
                <TextView
                    android:textSize="@dimen/ts_20"
                    android:textColor="@color/color_CC000000"
                    android:gravity="center"
                    android:id="@+id/alpha"
                    android:layout_width="0.0dip"
                    android:layout_height="fill_parent"
                    android:layout_weight="1.0"/>
                <TextView
                    android:textSize="@dimen/ts_24"
                    android:textColor="@color/color_FFFFFF"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:id="@+id/alphaAdd"
                    android:background="@drawable/button_dialog_main"
                    android:focusable="true"
                    android:layout_width="@dimen/vs_50"
                    android:layout_height="@dimen/vs_50"
                    android:text="+"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
