<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="@dimen/vs_50"
    android:paddingTop="@dimen/vs_50"
    android:paddingRight="@dimen/vs_50"
    android:paddingBottom="@dimen/vs_45"
    android:background="@drawable/app_bg">

    <!-- 全屏居中的背景ImageView -->
    <ImageView
        android:layout_width="@dimen/vs_120"
        android:layout_height="@dimen/vs_120"
        android:layout_centerInParent="true"
        android:src="@drawable/icon_empty"
        android:alpha="0.3" />

    <!-- 其他控件放在另一个容器中 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/vs_20"
            android:text="聚汇影视提示您：我居然崩溃了！"
            android:textColor="#FFD700"
            android:textSize="@dimen/vs_28"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="@dimen/vs_30"
            android:layout_height="@dimen/vs_30"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/vs_20" />

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="@dimen/vs_10"
            android:layout_weight="1"
            android:background="@drawable/button_dialog_main_1"
            android:padding="@dimen/vs_10"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvCrashLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:isScrollContainer="true"
                android:lineSpacingExtra="@dimen/vs_5"
                android:padding="@dimen/vs_10"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_16" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_10"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvShare"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/vs_10"
                android:layout_weight="1"
                android:background="@drawable/button_dialog_main_1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="@dimen/vs_15"
                android:text="复制日志"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_22"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRestart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/vs_10"
                android:layout_weight="1"
                android:background="@drawable/button_dialog_main_1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="@dimen/vs_15"
                android:text="重启应用"
                android:textColor="@android:color/white"
                android:textSize="@dimen/ts_22"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/vs_15"
            android:text="请把错误日志发送到：xuameng_1980@163.com，感谢支持！"
            android:textColor="@color/color_BBFFFFFF"
            android:textSize="@dimen/vs_20" />

    </LinearLayout>

</RelativeLayout>
