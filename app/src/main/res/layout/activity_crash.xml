<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="@dimen/vs_54"
    android:paddingTop="@dimen/vs_45"
    android:paddingRight="@dimen/vs_50"
    android:paddingBottom="@dimen/vs_54"
    android:background="@drawable/app_bg">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="聚汇影视居然崩溃了！"
        android:textColor="#FF6B6B"
        android:textSize="@dimen/vs_28"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/vs_20"
        android:layout_gravity="center_horizontal"/>

    <!-- 加载指示器 -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="@dimen/vs_30"
        android:layout_height="@dimen/vs_30"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/vs_20"/>

    <!-- 日志显示区域 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="崩溃日志信息"
        android:textColor="@android:color/white"
        android:textSize="@dimen/ts_24"
        android:layout_marginBottom="@dimen/vs_10"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="@dimen/vs_10"
        android:background="@drawable/button_dialog_main_1"
        android:padding="@dimen/vs_10"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tvCrashLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_16"
            android:fontFamily="monospace"
            android:lineSpacingExtra="@dimen/vs_5"
            android:padding="@dimen/vs_10"
            android:isScrollContainer="true"/>

    </ScrollView>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="@dimen/vs_10">

        <!-- 复制日志按钮 -->
<TextView
    android:id="@+id/tvShare"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:layout_marginEnd="@dimen/vs_10"
    android:text="复制日志"
    android:textColor="@android:color/white"
    android:textSize="@dimen/ts_22"
    android:textStyle="bold"
    android:gravity="center"
    android:paddingVertical="12dp"
    android:background="@drawable/button_dialog_main_1"
    android:focusable="true"
    android:clickable="true"/>

        <!-- 重启应用按钮 -->
        <TextView
            android:id="@+id/tvRestart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/vs_10"
            android:text="重启应用"
            android:textColor="@android:color/white"
            android:textSize="@dimen/ts_22"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="@dimen/vs_15"
            android:background="@drawable/button_dialog_main_1"
            android:focusable="true"
            android:clickable="true"/>

    </LinearLayout>

    <!-- 提示信息 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请把错误日志发送到：xuameng_1980@163.com，感谢支持！"
        android:textColor="#888888"
        android:textSize="@dimen/vs_20"
        android:layout_marginTop="@dimen/vs_15"
        android:layout_gravity="center_horizontal"/>

</LinearLayout>
