<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    android:paddingLeft="@dimen/vs_5"
    android:paddingTop="@dimen/vs_30"
    android:paddingRight="@dimen/vs_5"
    android:paddingBottom="@dimen/vs_30"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <TextView
            android:textSize="@dimen/ts_30"
            android:paddingLeft="@dimen/ts_43"
            android:paddingRight="@dimen/ts_43"
            android:textColor="@android:color/white"
            android:ellipsize="middle"
            android:id="@+id/tvTitle"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
        <TextView
            android:textSize="@dimen/ts_20"
            android:paddingLeft="@dimen/ts_43"
            android:paddingRight="@dimen/ts_43"
            android:textColor="@color/color_CCFFFFFF"
            android:ellipsize="middle"
            android:id="@+id/tvPath"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_10"
            android:singleLine="true"/>
        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/fileList"
            android:paddingLeft="@dimen/ts_43"
            android:paddingRight="@dimen/ts_43"
            android:paddingTop="@dimen/vs_10"
            android:paddingBottom="@dimen/vs_10"
            android:focusable="true"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:tv_horizontalSpacingWithMargins="20.0dip"
            app:tv_layoutManager="V7GridLayoutManager"
            app:tv_selectedItemIsCentered="true"
            app:tv_verticalSpacingWithMargins="@dimen/vs_10"
            android:layout_marginTop="@dimen/vs_20"/>
        <TextView
            android:textSize="@dimen/ts_22"
            android:textColor="@color/color_CCFFFFFF"
            android:gravity="center"
            android:id="@+id/tvEmpty"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_10"
            android:text="当前目录为空"/>
    </LinearLayout>
</FrameLayout>
